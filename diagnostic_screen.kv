<DiagnosticContent>:
    orientation: "vertical"
    md_bg_color: 0.06, 0.06, 0.06, 1

    MDTopAppBar:
        title: "Assistant Diagnostic"
        elevation: 4
        md_bg_color: 0.10, 0.10, 0.10, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(24)
        spacing: dp(20)
        adaptive_height: True
        pos_hint: {"center_x": .5, "center_y": .5}

        # السؤال بالفرنسية
        MDLabel:
            text: "Entendez-vous un bruit suspect ou un sifflement en accélérant ?"            
            font_style: "H6"
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        # زر الإجابة بنعم
        MDRaisedButton:
            text: "Oui, un sifflement aigu"
            pos_hint: {"center_x": .5}
            size_hint_x: 0.8
            md_bg_color: 0.12, 0.40, 0.70, 1
            on_release: print("Clic: Oui") # هنا يمكنك ربط الزر بالخطوة التالية لاحقاً

        # زر الإجابة بلا
        MDRaisedButton:
            text: "Non, aucun bruit anormal"
            pos_hint: {"center_x": .5}
            size_hint_x: 0.8
            md_bg_color: 0.20, 0.20, 0.20, 1
            on_release: print("Clic: Non")

    Widget: