<AccueilContent>:
    orientation: "vertical"
    md_bg_color: 0.06, 0.06, 0.06, 1

    MDTopAppBar:
        title: "Diesel Care - Accueil"
        elevation: 4
        md_bg_color: 0.10, 0.10, 0.10, 1

    ScrollView:
        do_scroll_x: False
        do_scroll_y: True

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(16)
            spacing: dp(16)
            size_hint_y: None
            height: self.minimum_height

            # ================= BANNER =================
            MDCard:
                size_hint_y: None
                height: dp(180)
                radius: [20]
                md_bg_color: 0.12, 0.12, 0.12, 1
                FitImage:
                    source: "images/img1.jpg"
                    radius: [20]

            # ================= SEARCH =================
            MDLabel:
                text: "Sélectionnez ou recherchez une panne"
                font_style: "H6"
                bold: True
                theme_text_color: "Custom"
                text_color: 0.12, 0.40, 0.70, 1 # اللون الأزرق الاحترافي المعتمد في تطبيقك
                size_hint_y: None
                height: self.texture_size[1]

            # ================= CARDS GRID =================
            MDGridLayout:
                cols: 2
                spacing: dp(12)
                adaptive_height: True

                # المربع 1: الدخان الأسود
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(180)
                    radius: [15]
                    ripple_behavior: True
                    md_bg_color: 0.12, 0.12, 0.12, 1
                    on_release:
                        app.root.ids.bottom_nav.switch_tab("pannes")
                        app.root.ids.pannes_ui.filtrer_panne("fap") 
                    FitImage:
                        source: "images/img2.png"
                        radius: [15, 15, 0, 0]
                    MDLabel:
                        text: "Fumée noire"
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 1,1,1,1
                        size_hint_y: None
                        height: dp(40)

                # المربع 2: التيربو
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(180)
                    radius: [15]
                    ripple_behavior: True
                    md_bg_color: 0.12, 0.12, 0.12, 1
                    on_release:
                        app.root.ids.bottom_nav.switch_tab("pannes")
                        app.root.ids.pannes_ui.filtrer_panne("turbo") 
                    
                    FitImage:
                        source: "images/img3.png"
                        radius: [15, 15, 0, 0]
                    MDLabel:
                        text: "Turbo"
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 1,1,1,1
                        size_hint_y: None
                        height: dp(40)
                # المربع 3: البخاخات
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(180)
                    radius: [15]
                    ripple_behavior: True
                    md_bg_color: 0.12, 0.12, 0.12, 1
                    on_release:
                        app.root.ids.bottom_nav.switch_tab("pannes")
                        app.root.ids.pannes_ui.filtrer_panne("injection") 
                    
                    
                    FitImage:
                        source: "images/img4.png"
                        radius: [15, 15, 0, 0]
                    MDLabel:
                        text: "Injecteurs"
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 1,1,1,1
                        size_hint_y: None
                        height: dp(40)
                # المربع 4: المحرك
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(180)
                    radius: [15]
                    ripple_behavior: True
                    md_bg_color: 0.12, 0.12, 0.12, 1
                    on_release:
                        app.root.ids.bottom_nav.switch_tab("pannes")
                        app.root.ids.pannes_ui.filtrer_panne("moteur") 
                    
                    FitImage:
                        source: "images/img5.png"
                        radius: [15, 15, 0, 0]
                    MDLabel:
                        text: "Moteur"
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 1,1,1,1
                        size_hint_y: None
                        height: dp(40)